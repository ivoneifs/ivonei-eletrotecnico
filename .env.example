# Supabase — logical/GitHub name: ivonei-eletrotecnico
# Self-hosted / AppsBrasil (NÃO é supabase.com cloud)
#
# Studio project ref (AppsBrasil): usually `default` — NOT /ivonei-eletrotecnico
# Dashboard: https://supabase.appsbrasil.store/project/default
# API keys:  https://supabase.appsbrasil.store/project/default/settings/api
#
# Copy this file to .env and paste the anon (public) key from Settings → API.
# Never commit .env. Never use the service_role key in the browser.

# Project URL = Kong API gateway (NOT a Studio page path like /project/default)
# Probed: /auth/v1/health and /rest/v1/ return "No API key found" on this host
SUPABASE_URL=https://supabase.appsbrasil.store

# Alternate candidate (may not resolve on all DNS setups — keep documented)
# SUPABASE_URL=https://api.supabase.appsbrasil.store

SUPABASE_ANON_KEY=your_anon_public_key_here

# Optional aliases for tooling / static frontends
VITE_SUPABASE_URL=https://supabase.appsbrasil.store
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here
